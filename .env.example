# ============================================
# SECURITY DOCS: ENVIRONMENT VARIABLES
# ============================================

# [1] PUBLIC VARIABLES (NEXT_PUBLIC_*)
# --------------------------------------------
# These variables ARE EXPOSED to the browser and the client.
# DO NOT put sensitive keys, passwords, or direct DB connection strings here.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your deployment URL — used by sitemap.ts, robots.ts for canonical URLs.
# Example: https://heru-store.vercel.app  (no trailing slash)
# For local development: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# [2] SECRET VARIABLES (Server-side ONLY)
# --------------------------------------------
# These variables are strictly accessible ONLY on the server-side logic (e.g. Server Actions, API routes).
# They MUST NOT be exposed to the client to prevent critical data breaches.
# Note: NEVER prefix these with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here_never_share_this

# [3] EMAIL SERVICE (Server-side ONLY)
# --------------------------------------------
# Resend API configuration for order notification dispatch
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=orders@yourdomain.com

# ============================================
# ⚠️  SUPABASE DASHBOARD CONFIGURATION
# ============================================
# For the password-reset email flow to work correctly you MUST configure
# the following in: Supabase Dashboard → Authentication → URL Configuration
#
# 1. Site URL
#    Set this to your PRODUCTION domain, e.g.:
#      https://your-production-domain.com
#
# 2. Redirect URLs (add ALL of these)
#    https://your-production-domain.com/auth/callback
#    http://localhost:3000/auth/callback
#
# Without these settings, Supabase will insert localhost into every
# email link it sends, causing ERR_CONNECTION_REFUSED in production.
# ============================================
